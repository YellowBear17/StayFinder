<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Price Range -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max price per night"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0"
                android:textSize="12sp"
                android:textColor="#717171"/>

            <SeekBar
                android:id="@+id/seek_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:progressTint="#FF385C"
                android:thumbTint="#FF385C"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱10k+"
                android:textSize="12sp"
                android:textColor="#717171"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txt_price_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Any"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF385C"
            android:layout_marginBottom="8dp"/>

        <!-- Manual price input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginRight="6dp"/>

            <EditText
                android:id="@+id/input_price_exact"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Enter exact amount"
                android:inputType="number"
                android:background="@drawable/rounded_edittext_dark"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:textColor="#222222"
                android:textColorHint="#AAAAAA"/>

            <TextView
                android:id="@+id/btn_apply_exact_price"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Set"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_view_details"
                android:gravity="center"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_marginLeft="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Property Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Property type"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="12dp"/>

        <!-- Type chips added programmatically -->
        <LinearLayout
            android:id="@+id/filter_type_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>
