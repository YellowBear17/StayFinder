<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_weight="0"
    android:orientation="horizontal"
    android:background="@drawable/bottom_nav_bg"
    android:elevation="8dp">

    <LinearLayout
        android:id="@+id/nav_explore"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Explore" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_wishlist"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_wishlist"/>
        <TextView android:id="@+id/nav_wishlist_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Wishlist" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_trips"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_trips"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Trips" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Host-only: My Listings (hidden by default) -->
    <LinearLayout
        android:id="@+id/nav_my_listings"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Listings" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_inbox"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <FrameLayout android:layout_width="22dp" android:layout_height="22dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_inbox"/>
            <TextView
                android:id="@+id/inbox_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="16dp"
                android:text="0"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/notification_dot"
                android:gravity="center"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:layout_gravity="top|end"
                android:visibility="gone"/>
        </FrameLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Inbox" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_profile"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Profile" android:textSize="10sp" android:textColor="#717171" android:layout_marginTop="2dp"/>
    </LinearLayout>

</LinearLayout>
