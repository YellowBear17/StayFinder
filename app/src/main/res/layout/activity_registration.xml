<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_overlay"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:paddingTop="60dp"
        android:paddingBottom="32dp"
        android:gravity="top|center_horizontal">

        <!-- Logo Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="stay"
                android:textSize="42sp"
                android:textColor="#ffffff"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finder"
                android:textSize="42sp"
                android:textColor="#3498DB"
                android:fontFamily="sans-serif-medium"
                android:textStyle="italic"/>
        </LinearLayout>

        <!-- Step 1: Google Sign-In (shown first) -->
        <LinearLayout
            android:id="@+id/step_google"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create your account"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in with Google to get started"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="32dp"/>

            <!-- Google Sign-In Button -->
            <LinearLayout
                android:id="@+id/btn_google_signin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/rounded_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#EA4335"
                    android:layout_marginRight="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue with Google"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#222222"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A Google account is required to register."
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>

        <!-- Step 2: Registration Form (hidden until Google step done) -->
        <LinearLayout
            android:id="@+id/step_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personal Details"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/reg_firstname"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="First name"
            android:inputType="textPersonName"
            android:background="@drawable/rounded_edittext"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/reg_lastname"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Last name"
            android:inputType="textPersonName"
            android:background="@drawable/rounded_edittext"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/reg_contact"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Contact number (e.g. 09123456789)"
            android:inputType="phone"
            android:maxLength="11"
            android:background="@drawable/rounded_edittext"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- Account Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/reg_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:background="@drawable/rounded_edittext"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <!-- Password field with eye toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="28dp">

            <EditText
                android:id="@+id/reg_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Password"
                android:inputType="textPassword"
                android:background="@drawable/rounded_edittext"
                android:paddingLeft="16dp"
                android:paddingRight="52dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#CCCCCC"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/toggle_reg_password"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:text="👁"
                android:textSize="18sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <!-- Role Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I am a..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btn_role_user"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Guest / User"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/role_btn_selected"
                android:layout_marginRight="8dp"/>

            <Button
                android:id="@+id/btn_role_host"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Host"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/role_btn_unselected"
                android:layout_marginLeft="8dp"/>

        </LinearLayout>

        <!-- Create Account Button -->
        <Button
            android:id="@+id/btn_create_account_submit"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:text="Create account"
            android:textColor="#3498DB"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button"
            android:paddingLeft="48dp"
            android:paddingRight="48dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/already_have_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Sign in"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"
            android:clickable="true"/>

        </LinearLayout><!-- end step_form -->

    </LinearLayout>

</ScrollView>
